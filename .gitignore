# Virtual environments
.venv/
venv/

# Python caches
__pycache__/
*.pyc
.pyre/

# Test / lint caches
.pytest_cache/
.ruff_cache/

# OS
.DS_Store

# Generated artifacts
# ----------------------------------------------------------------------------
# Detection results for every analyzed project are versioned, EXCEPT:
#   - source checkouts under dest/projects/ (cloned on demand)
#   - individual files too large for GitHub (100 MB hard limit), listed below
# Adding a new project usually needs no edits here: just commit its result
# files. Only oversized files require an explicit exclusion line.
# ----------------------------------------------------------------------------
/dest/*

# Per-project source checkouts are cloned on demand and never versioned.
dest/projects/

# Lightweight detection results (JSON), all projects.
!/dest/analysis_params/
!/dest/clone_metrics/
!/dest/services_json/

# Enriched fragments and scatter datasets (CSV), all projects.
!/dest/enriched_fragments/
!/dest/scatter/

# --- Oversized files excluded from version control (GitHub 100 MB limit) ----
# Add one line per file that is too large to push. The Stats View still works
# from enriched_fragments + clone_metrics, so excluding a scatter CSV only
# drops that one language's scatter plot.
#
# FudanSELab.train-ticket: the JavaScript scatter is ~457 MB (bundled
# libraries inflate the clone count), so it is excluded; Java is kept.
/dest/scatter/FudanSELab.train-ticket/csv/*_JavaScript.csv

/scratch/

# External dataset (download separately)
/dataset/*
!/dataset/.gitkeep

# Local tool settings
/.claude/
